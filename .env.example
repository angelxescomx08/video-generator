# ---- Postgres ----
POSTGRES_USER=videogen
POSTGRES_PASSWORD=changeme
POSTGRES_DB=videogen
DATABASE_URL=postgresql://videogen:changeme@localhost:5432/videogen

# ---- pg-boss ----
PGBOSS_SCHEMA=pgboss

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- AI provider selection (fallback if no provider_configs DB row) ----
AI_PROVIDER=ollama                # ollama | openai | gemini | anthropic
EMBEDDING_PROVIDER=ollama         # independent from AI_PROVIDER (anthropic has no embeddings API)

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- TTS provider selection ----
TTS_PROVIDER=piper                # piper | coqui | elevenlabs | azure
TTS_BASE_URL=http://localhost:5002

ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

AZURE_TTS_KEY=
AZURE_TTS_REGION=

# ---- Stock footage providers (free ones can be enabled together) ----
PIXABAY_API_KEY=
PEXELS_API_KEY=
SHUTTERSTOCK_API_KEY=
SHUTTERSTOCK_API_SECRET=
STORYBLOCKS_API_KEY=
STORYBLOCKS_PRIVATE_KEY=
STORYBLOCKS_PROJECT_ID=

# ---- Social platforms (OAuth) ----
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/oauth/youtube/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/oauth/facebook/callback

# ---- Secrets ----
TOKEN_ENCRYPTION_KEY=changeme-32-byte-minimum-secret-key

# ---- Worker/render ----
# IMPORTANT: use an ABSOLUTE path here, not a relative one. In native dev (non-Docker), apps/web
# and apps/worker run from different working directories — a relative path like "./data/renders"
# resolves to a different real folder for each process, so web can't find files the worker wrote.
# Example (adjust to your machine): C:/Users/you/projects/video-generator/data/renders
RENDER_OUTPUT_DIR=/absolute/path/to/video-generator/data/renders
WORKER_TMP_DIR=/absolute/path/to/video-generator/data/tmp
FFMPEG_PATH=
